{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "ScraperBackendService": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Extensions.Hosting": "Warning",
      "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
      "Microsoft.AspNetCore.Routing.EndpointMiddleware": "Warning",
      "Microsoft.AspNetCore.StaticFiles": "Warning",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "Console": {
    "FormatterName": "simple",
    "FormatterOptions": {
      "SingleLine": true,
      "IncludeScopes": false,
      "TimestampFormat": "HH:mm:ss ",
      "UseUtcTimestamp": false,
      "MaxQueueLength": 100,
      "QueueFullWaitTime": 1000
    }
  },
  "ServiceConfig": {
    "Port": 8585,
    "Host": "0.0.0.0",
    "AuthToken": "",
    "TokenHeaderName": "X-API-Token",
    "MaxConcurrentRequests": 2,
    "RateLimitSeconds": 5,
    "RequestTimeoutSeconds": 180,
    "EnableAggressiveMemoryOptimization": true,
    "ChallengeAutoWaitSeconds": 30,
    "ChallengeAutoWaitSlowSeconds": 60,

    "EnableManualChallengeResolution": true,
    "ManualChallengeTimeoutSeconds": 180,
    "ManualChallengeWindowWidth": 1280,
    "ManualChallengeWindowHeight": 900,

    "EnableCookiePersistence": true,
    "AutoLoadCookiesOnContextCreation": true,
    "PreferSystemChromeForHeadless": true,

    "CacheTtlMinutes": 2,
    "CacheNullResultTtlMinutes": 2,
    "CacheSizeLimitEntries": 100
  }
}